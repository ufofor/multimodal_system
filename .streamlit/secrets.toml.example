# Copy this to .streamlit/secrets.toml and fill in your keys (local dev only).
# On Streamlit Community Cloud, paste these under Advanced settings → Secrets.

ANTHROPIC_API_KEY = "sk-ant-..."
OPENAI_API_KEY = "sk-..."
LANGCHAIN_API_KEY = "ls__..."
LANGCHAIN_TRACING_V2 = "true"
LANGCHAIN_PROJECT = "enterprise-doc-assistant"
PINECONE_API_KEY = "..."
PINECONE_INDEX = "docintel"
